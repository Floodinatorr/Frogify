void setup() {

  Serial.begin(115200);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print(".");
    delay(500);
  }
  Serial.println("");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  webSocket.begin();
  webSocket.onEvent(serverLoop);

  display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS);
  display.clearDisplay();
  display.display();

  arm.attach(16, 500, 2400);
  arm2.attach(0, 500, 2400);

  pinMode(12, OUTPUT);
  pinMode(13, OUTPUT);
  pinMode(14, OUTPUT);
  pinMode(15, OUTPUT);
  pinMode(buzzer, OUTPUT);
}

void turn(int degree) {
  arm.write(degree);
  arm2.write(180 - degree);
}

int isEqual(const char* data1, const char* data2) {
  int x = strcmp(data1, data2);
  return x == 0 ? 1 : 0;
}

void move(const char* type) {
  Serial.println(type);
  Serial.println(isEqual(type, "f"));
  if (isEqual(type, "f")) {
    digitalWrite(14, HIGH);
    digitalWrite(12, LOW);
    digitalWrite(13, LOW);
    digitalWrite(15, HIGH);
  } else if (isEqual(type, "b")) {
    digitalWrite(14, LOW);
    digitalWrite(12, HIGH);
    digitalWrite(13, HIGH);
    digitalWrite(15, LOW);
  } else if (isEqual(type, "r")) {
    digitalWrite(14, LOW);
    digitalWrite(12, HIGH);
    digitalWrite(13, LOW);
    digitalWrite(15, HIGH);
  } else if (isEqual(type, "l")) {
    digitalWrite(14, HIGH);
    digitalWrite(12, LOW);
    digitalWrite(13, HIGH);
    digitalWrite(15, LOW);
  } else {
    digitalWrite(14, LOW);
    digitalWrite(12, LOW);
    digitalWrite(13, LOW);
    digitalWrite(15, LOW);
  }
  
  delay(50);
}

void play(int a) {
  digitalWrite(buzzer, a);
}

void loadMode(int percent) {
  if (percent >= 0 || percent <= 100) {
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(WHITE);
    display.setCursor(10, 5);
    display.println("LOADING... PLS WAIT");
    display.setCursor(10, 18);
    display.print(percent);
    display.println("%");
    display.drawRect(40, 18, 83, 8, WHITE);
    display.fillRect(40, 18, map(percent, 0, 100, 2, 82), 8, WHITE);
    display.display();
  }
}

void changeEyes(int eye_no) {
  if (eye_no < 0 || eye_no > 7) {
    giveError("False eye no!");
  } else {
    display.clearDisplay();
    display.drawBitmap(0, 0, eyes[eye_no], 40, 32, 1);
    display.drawBitmap(display.width() - 40, display.height() - 32, eyes[eye_no], 40, 32, 1);
    display.display();
  }
}

void giveError(String error) {
  Serial.println(error);
}

void loop() {
  webSocket.loop();
}

void serverLoop(uint8_t num, WStype_t type, uint8_t* payload, size_t length) {
  if (type == WStype_TEXT) {
    String myData = String((const char*)payload);
    DynamicJsonDocument doc(2048);
    DeserializationError err = deserializeJson(doc, myData);
    JsonObject obj = doc.as<JsonObject>();
    if (err) {
      giveError("JSON library failed.");
    } else {
      errorStatus = (int)obj["error"];
      loadStatus = (int)obj["loadMode"];
      if (errorStatus) {
        errorString = String(obj[errorString]);
        giveError(errorString);
      } else if (loadStatus) {
        loadPercent = (int)obj["loadPercent"];
        loadMode(loadPercent);
      } else {
        bzrStatus = (int)obj["buzzer"];
        eyeNo = (int)obj["eyeNo"];
        armPos = (int)obj["arm"];
        const char* moveType = obj["moveType"];
        Serial.println(moveType);
        play(bzrStatus);
        changeEyes(eyeNo);
        turn(armPos);
        move(moveType);
      }
    }
  }
}
